# ============================================
# ShubhaSamagri Chatbot - Environment Config
# ============================================
# Copy this file to .env and fill in values

# --- LLM Provider (choose one) ---
# Get FREE Groq API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Optional: Google Gemini fallback ---
# Get FREE at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- LLM Configuration ---
LLM_PROVIDER=groq                           # groq | gemini
GROQ_MODEL=llama-3.3-70b-versatile         # Best quality (free)
# GROQ_MODEL=llama-3.1-8b-instant          # Faster, lower quality
GEMINI_MODEL=gemini-1.5-flash-latest       # Fallback

# --- Embedding Model ---
# paraphrase-multilingual-MiniLM-L12-v2 → supports Hindi, Telugu, Tamil, Sanskrit, English
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- Vector Store ---
CHROMA_PERSIST_DIR=./chroma_db             # Where to store ChromaDB data

# --- Spring Boot API (for real-time sync) ---
SPRING_BOOT_API_URL=http://localhost:8080/api

# --- Server ---
PORT=8001
